# Copy to `.env.local` for development, and set the same keys in your hosting
# provider's environment settings for production. `.env*` is gitignored — this
# template is the only one of these files that belongs in the repository.

# ─── Required in production ──────────────────────────────────────────────────

# The public origin, no trailing slash. Every canonical URL, Open Graph image,
# sitemap entry and robots directive is built from it. On Vercel this falls back
# to VERCEL_PROJECT_PRODUCTION_URL automatically, so it is only strictly needed
# once a custom domain is attached — but set it the moment one is.
NEXT_PUBLIC_SITE_URL=https://southeastmedia.com

# ─── Contact form delivery (set at least one group) ──────────────────────────
#
# With neither configured the form still accepts submissions, but the enquiry
# only reaches the runtime logs. See lib/contact-delivery.ts.

# Email, via Resend (https://resend.com). CONTACT_FROM_EMAIL must be on a domain
# verified in the Resend dashboard or every send is rejected.
RESEND_API_KEY=
CONTACT_TO_EMAIL=studio@southeastmedia.com
CONTACT_FROM_EMAIL=Southeast Media <enquiries@southeastmedia.com>

# Or POST each enquiry as JSON. Works as-is with a Slack or Teams incoming
# webhook. Can be set alongside the email transport.
CONTACT_WEBHOOK_URL=
